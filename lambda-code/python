import json
import boto3
from botocore.exceptions import ClientError


# -----------------------------
# Helpers
# -----------------------------

def _err_to_text(e: Exception) -> str:
    if isinstance(e, ClientError):
        code = e.response.get("Error", {}).get("Code", "ClientError")
        msg = e.response.get("Error", {}).get("Message", str(e))
        return f"{code}: {msg}"
    return str(e)


